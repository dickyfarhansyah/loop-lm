PORT=8080
NODE_ENV=development
DATABASE_URL=./data/webui.db
JWT_SECRET=change-this-secret-in-production
JWT_EXPIRES_IN=7d
CORS_ALLOW_ORIGIN=*
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
WEBUI_NAME=LoopLM

# ChromaDB - use embedded mode (no Docker needed) or HTTP mode
# Leave empty to use embedded persistent mode
CHROMA_MODE=embedded
CHROMA_PERSIST_DIR=./data/chroma
# Or set CHROMA_URL to point to a running ChromaDB HTTP server
# CHROMA_URL=http://localhost:8000

CHUNK_SIZE=1000
CHUNK_OVERLAP=200
